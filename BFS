#include<iostream>
using namespace std;

#define MAX 10

int main()
{
    int graph[MAX][MAX];
    int visited[MAX] = {0};
    int queue[MAX];
    int front = 0;
    int rear = 0;
    int n, start;

    cout << "Enter the no. of vertices: ";
    cin >> n;

    cout << "Enter the adjacency matrix:\n";
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            cin >> graph[i][j];
        }
    }

    cout << "Enter starting vertex: ";
    cin >> start;

    // BFS
    queue[rear++] = start;
    visited[start] = 1;

    cout << "BFS Traversal: ";

    while(front < rear)
    {
        int v = queue[front++];
        cout << v << " ";

        for(int i = 0; i < n; i++)
        {
            if(graph[v][i] == 1 && visited[i] == 0)
            {
                queue[rear++] = i;
                visited[i] = 1;
            }
        }
    }

    return 0;
}
