#include<iostream>
using namespace std;

struct stack {
    int info;
    stack* next;
};

bool checkEmpty(stack* top) {
    return top == NULL;
}

void push(stack* &top, int data) {
    stack* newNode = new stack;
    newNode->info = data;
    newNode->next = top;
    top = newNode;
    cout << data << " pushed" << endl;
}

void pop(stack* &top) {
    if(checkEmpty(top)) {
        cout << "Empty Stack" << endl;
        return;
    }

    stack* temp = top;
    top = top->next;
    cout << temp->info << " popped" << endl;
    delete temp;
}

void traverse(stack* top) {
    if(checkEmpty(top)) {
        cout << "Stack is Empty" << endl;
        return;
    }

    while(top != NULL) {
        cout << top->info << " ";
        top = top->next;
    }
    cout << endl;
}

int main() {
    stack* top = NULL;
    int choice, data;

    do {
        cout << "\n1.Push 2.Pop 3.CheckEmpty 4.Traverse 5.Exit\n";
        cin >> choice;

        switch(choice) {
            case 1:
                cin >> data;
                push(top, data);
                break;

            case 2:
                pop(top);
                break;

            case 3:
                if(checkEmpty(top))
                    cout << "Stack is Empty\n";
                else
                    cout << "Stack is not Empty\n";
                break;

            case 4:
                traverse(top);
                break;

            case 5:
                cout << "Exit\n";
                break;

            default:
                cout << "Invalid choice\n";
        }

    } while(choice != 5);

    return 0;
}
